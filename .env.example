# Supabase project settings — from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser.
# Used only by scripts/create-admin.mjs to create the Master Admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Master Admin credentials (used once by `npm run create-admin`)
ADMIN_EMAIL=admin@bjymcg.local
ADMIN_PASSWORD=bjym2026
